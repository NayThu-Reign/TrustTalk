{
  "name": "trusttalk-demo",
  "private": true,
  "version": "0.12.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "NODE_OPTIONS='--use-system-ca' concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:electron": "NODE_OPTIONS='--use-system-ca' electron .",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.trustlinkmm.trusttalk",
    "productName": "TrustTalk-Demo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/splash_logo_tl_2.ico"
    },
    "linux": {
      "icon": "assets/splash_logo_tl2.png"
    },
    "mac": {
      "icon": "src/assets/splash.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "proxy": "http://192.168.10.244:3001",
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fontsource/roboto": "^5.1.0",
    "@mui/icons-material": "^6.1.4",
    "@mui/material": "^6.1.4",
    "@mui/styled-engine-sc": "^6.1.4",
    "@privacyresearch/libsignal-protocol-typescript": "^0.0.16",
    "@signalapp/libsignal-client": "^0.83.0",
    "@tanstack/react-query": "^5.67.2",
    "better-sqlite3": "^12.6.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.12.0",
    "framer-motion": "^11.11.10",
    "idb": "^8.0.3",
    "immer": "^10.1.1",
    "js-cookie": "^3.0.5",
    "libsodium-wrappers": "^0.7.15",
    "libsodium-wrappers-sumo": "^0.7.15",
    "linkify-react": "^4.3.1",
    "localforage": "^1.10.0",
    "lodash": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.0",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^2.0.5",
    "react-linkify": "^1.0.0-alpha",
    "react-router-dom": "^6.30.0",
    "react-slick": "^0.30.3",
    "react-virtualized-auto-sizer": "^1.0.25",
    "react-window": "^1.8.11",
    "slick-carousel": "^1.8.1",
    "socket.io-client": "^4.8.0",
    "styled-components": "^6.1.13",
    "use-immer": "^0.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.11.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "vite": "^6.3.6",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
